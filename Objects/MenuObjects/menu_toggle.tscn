[sub_resource type="GDScript" id="GDScript_lrsv1"]
script/source = "extends AnimatedSprite2D
#the name of the setting you want to change
var settingName: String

func _ready() -> void:
	#set it to the metadata and set the checkbox accordingly
	settingName = get_parent().get_meta(\"valueName\")
	animation = str(Settings.settingsValues[settingName])

func _process(_delta: float) -> void:
	#update the checkbox
	animation = str(Settings.settingsValues[settingName])
"

