[sub_resource type="GDScript" id="GDScript_fi8a0"]
script/source = "extends Control


#change visiblility dependant on if remapping is happening
func _process(_delta: float) -> void:
	if get_parent().currentRemapK:
		visible = true
	else:
		visible = false
"

