[sub_resource type="GDScript" id="GDScript_070r5"]
script/source = "extends Label

var parents: Array[Node]

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	parents = [get_parent(), get_parent().get_parent(), get_parent().get_parent().get_parent(), get_parent().get_parent().get_parent().get_parent()]
	parents[0].visible = false


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	#print(parents)
	parents[1].rotation = -parents[3].rotation
	if parents[2].player != null:
		if parents[2].player.charVal == parents[2].player.SUPPORT_VAL:
			parents[1].visible = false
			return
		else:
			parents[1].visible = true
		text = str(MiscGlobals.manas[parents[2].player.charVal]) + \"/\" + str(MiscGlobals.maxManas[parents[2].player.charVal])
		if parents[2].player.followPos == parents[2].player.BATTLE_VAL:
			#parents[2].position = Vector2(0,0)
			var x = \"a\"
		else:
			parents[2].global_position = parents[2].player.global_position
		
	else:
		parents[1].visible = false
"

